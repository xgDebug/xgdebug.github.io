    <item>
      <title>一些中国人</title>
      <link>https://www.xgdebug.com/posts/2023/wordpress/%E4%B8%80%E4%BA%9B%E4%B8%AD%E5%9B%BD%E4%BA%BA/</link>
      <pubDate>Thu, 03 Aug 2023 22:46:49 +0000</pubDate>
